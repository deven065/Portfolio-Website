# Email Configuration — Resend (https://resend.com)
# 1. Sign up free at resend.com
# 2. Get your API key from the dashboard
# 3. Verify your sending domain (devendigitallabs.com)
RESEND_API_KEY=re_YOUR_API_KEY_HERE
ADMIN_EMAIL=hello@devendigitallabs.com
FROM_EMAIL=noreply@devendigitallabs.com

# Razorpay Payment Gateway Configuration
# Get your keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id

# Website URL (used for invoice payment links)
WEBSITE_URL=http://localhost:8080
